{
  "name": "@fanxlab/tavily-key-rotator",
  "version": "1.0.0",
  "description": "Auto-rotates Tavily API keys on 429 rate limit errors for OpenClaw",
  "type": "module",
  "main": "index.js",
  "openclaw": {
    "extensions": ["./index.js"],
    "build": {
      "openclawVersion": "2026.4.22"
    },
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "tavily",
    "api-key",
    "rate-limit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fanxlab/tavily-key-rotator"
  }
}
